    "prettier-plugin-astro-organize-imports": "^0.4.11",
    "prettier-plugin-tailwindcss": "^0.6.9"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "yaml-language-server": {
      "yaml": "2.8.3"
