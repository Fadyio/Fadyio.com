    "@hbsnow/rehype-sectionize": "^1.0.7",
    "@iconify-json/lucide": "^1.2.86",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.6",
    "astro": "^6.4.8",
