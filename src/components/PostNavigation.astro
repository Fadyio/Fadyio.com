---
import type { CollectionEntry } from "astro:content"

type Post = CollectionEntry<"blog">
type Props = { prev?: Post; next?: Post }

const { prev, next } = Astro.props
---

{(prev || next) && (
    <nav class="post-nav" aria-label="Post navigation">
      {prev ? (
        <a class="prev" href={`/blog/${prev.id}`}>
          <span class="dir">&larr; Previous</span>
          <span class="title">{prev.data.title}</span>
        </a>
      ) : (
        <span />
      )}
      {next ? (
        <a class="next" href={`/blog/${next.id}`}>
          <span class="dir">Next &rarr;</span>
          <span class="title">{next.data.title}</span>
        </a>
      ) : (
        <span />
      )}
    </nav>
  )}

<style>
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-s);
    margin-block-start: var(--space-xl);
    padding-block-start: var(--space-m);
    border-block-start: 1px solid var(--border);
  }

  a {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding: var(--space-s);
    color: var(--foreground);
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    text-decoration: none;

    &:hover {
      border-color: var(--accent);
    }
  }

  a.next {
    text-align: right;
  }

  .dir {
    font-size: var(--step--1);
    color: var(--muted-foreground);
  }

  .title {
    font-weight: var(--font-weight-medium);
    line-height: calc(var(--leading-offset) + 1em);
  }

  a:hover .title {
    text-decoration: underline;
    text-decoration-color: currentColor;
    text-underline-offset: 0.15em;
  }

  @media (width < 32rem) {
    .post-nav {
      grid-template-columns: 1fr;
    }

    a.next {
      text-align: left;
    }
  }
</style>
