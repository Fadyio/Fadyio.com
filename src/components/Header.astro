---
import ThemeToggle from "@/components/ThemeToggle.astro"
import { NAVIGATION, SITE } from "@/consts"
import { normalizePath } from "@/lib/utils"

const pathname = normalizePath(Astro.url.pathname) || "/"
const isActive = (href: string) =>
  href.startsWith("/") && !href.includes(".")
    ? pathname === href || pathname.startsWith(`${href}/`)
    : false
---

<header id="site-header">
  <div class="header-inner">
    <a class="brand" href="/" aria-label={SITE.title}>
      <img src="/static/logo.webp" alt="" width="28" height="28">
      <span>{SITE.title}</span>
    </a>
    <div class="header-actions">
      <nav aria-label="Main navigation">
        <ul>
          {NAVIGATION.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  #site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background-color: color-mix(in oklab, var(--background) 80%, transparent);
    backdrop-filter: blur(var(--blur-md));
    border-block-end: 1px solid var(--border);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
    will-change: transform;
  }

  #site-header[data-hidden]:not(:focus-within) {
    transform: translateY(-100%);
    opacity: 0;
  }

  .header-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s);
    inline-size: 100%;
    max-inline-size: var(--container-max);
    min-block-size: var(--header-height);
    margin-inline: auto;
    padding-inline: var(--space-s);
    padding-block: var(--space-2xs);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    font-size: var(--step-1);
    font-weight: var(--font-weight-medium);
    color: var(--foreground);
    text-decoration: none;
    transition: color 0.2s ease;

    img {
      inline-size: 1.75rem;
      block-size: 1.75rem;
      flex-shrink: 0;
    }

    &:hover {
      color: var(--accent);
    }
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-s);
  }

  nav ul {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--step-0);

    a {
      color: var(--muted-foreground);
      text-decoration: none;
      transition: color 0.2s ease;

      &:hover,
      &[aria-current="page"] {
        color: var(--foreground);
      }
    }
  }

  @media (width < 32rem) {
    nav ul {
      gap: var(--space-xs);
      font-size: var(--step--1);
    }

    .brand span {
      display: none;
    }
  }
</style>

<script>
  const header = document.getElementById("site-header")

  if (header) {
    let lastY = window.scrollY
    let ticking = false

    const update = () => {
      const y = window.scrollY
      if (y > lastY && y > 80) {
        header.dataset.hidden = "true"
      } else {
        delete header.dataset.hidden
      }
      lastY = y
      ticking = false
    }

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update)
          ticking = true
        }
      },
      { passive: true },
    )
  }
</script>
